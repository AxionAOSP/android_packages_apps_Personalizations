<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:title="@string/always_on_display_title" >

    <com.android.settingslib.widget.MainSwitchPreference
        android:key="doze_main_switch"
        android:title="@string/doze_always_on_title"
        app:defaultValue="false" />

    <PreferenceCategory
        android:title="@string/ambient_display_when_to_show"
        android:key="when_to_show_category">

        <com.android.settings.preferences.RadioButtonPreference
            android:key="doze_always_on"
            android:title="@string/ambient_display_always_title"
            android:summary="@string/ambient_display_always_summary"
            android:dependency="doze_main_switch" />

        <com.android.settings.preferences.RadioButtonPreference
            android:key="doze_schedule"
            android:title="@string/ambient_display_schedule_title"
            android:summary="@string/ambient_display_schedule_summary"
            android:dependency="doze_main_switch" />

        <Preference
            android:key="doze_start_time"
            android:title="@string/ambient_display_start_time"
            android:visibility="gone"
            android:dependency="doze_main_switch" />

        <Preference
            android:key="doze_end_time"
            android:title="@string/ambient_display_end_time"
            android:visibility="gone"
            android:dependency="doze_main_switch" />

        <com.android.settings.preferences.RadioButtonPreference
            android:key="doze_charging"
            android:title="@string/ambient_display_charging_title"
            android:summary="@string/ambient_display_charging_summary"
            android:dependency="doze_main_switch" />
    </PreferenceCategory>
    
    <com.android.settings.preferences.SystemSettingSwitchPreference
        android:key="screen_off_aod_enabled"
        android:title="@string/screen_off_aod_enabled"
        android:summary="@string/screen_off_aod_enabled_summary"
        android:defaultValue="false" />
</PreferenceScreen>
